@'
PORT=4000

SEARCH_PROVIDERS=drushim,matrix,jobmaster,alljobs,sites

DEBUG_JOBS=false
DEBUG_JOB_LIMIT=10
DEBUG_DRY_RUN=false
SAVE_PARTIAL_RESULTS=false
MIN_SAVE_SCORE=45

SERPAPI_API_KEY=
SERPAPI_PAGES_PER_QUERY=1

GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:4000/api/gmail/oauth2callback
CLIENT_URL=http://localhost:5173
GMAIL_IMPORT_DAYS=14
GMAIL_IMPORT_MAX_RESULTS=40
'@ | Set-Content .\server\.env.example -Encoding UTF8
PORT=4000

# Providers recommended for precise results first.
# Add jobmaster/alljobs only after testing because they can return noisy search/category pages.
SEARCH_PROVIDERS=drushim,matrix

# Optional debug mode
DEBUG_JOBS=false
DEBUG_JOB_LIMIT=10
DEBUG_DRY_RUN=false
SAVE_PARTIAL_RESULTS=false
MIN_SAVE_SCORE=45

# Optional only if you use serpapi provider
SERPAPI_API_KEY=put_your_key_here
SERPAPI_PAGES_PER_QUERY=1
# Optional scan controls
# Limits how many query/provider chunks are processed in one click. 0 = full scan.
SCAN_BATCH_SIZE=0
# Limits total query count before multiplying by providers. 0 = all queries.
SCAN_MAX_QUERIES=0
# Faster Playwright defaults
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=15000
PLAYWRIGHT_WAIT_MS=800
# Site source provider tuning if you enable SEARCH_PROVIDERS=sites
SITE_SOURCES_MAX_SOURCES=4
SITE_SOURCE_RESULTS_PER_SOURCE=4


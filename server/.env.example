PORT=4000

# Providers recommended for precise results first.
# Add jobmaster/alljobs only after testing because they can return noisy search/category pages.
SEARCH_PROVIDERS=drushim,matrix

# Optional debug mode
DEBUG_JOBS=false
DEBUG_JOB_LIMIT=10
DEBUG_DRY_RUN=false
SAVE_PARTIAL_RESULTS=false
MIN_SAVE_SCORE=45

# Optional only if you use serpapi provider
SERPAPI_API_KEY=put_your_key_here
SERPAPI_PAGES_PER_QUERY=1
